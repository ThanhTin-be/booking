# IP máy chạy backend server (thay bằng IP thực của máy bạn)
# Lấy IP: ipconfig getifaddr en0  (macOS)
#          ipconfig (Windows - xem IPv4 Address)
API_BASE_URL=http://<IP_CUA_BAN>:5000/api

